# Copia este archivo a .env y ajusta lo que necesites:
#   cp .env.example .env
#
# Compose lee .env automáticamente. run.sh también.

# ── Imagen / build ─────────────────────────────────────────────────────
IMAGE_TAG=fedmammobench:latest
# Imagen base del Dockerfile (déjala así salvo que sepas lo que haces).
BASE_IMAGE=python:3.11-slim-bookworm

# ── Configs del experimento ────────────────────────────────────────────
# Para 5 nodos:
# SERVER_CONFIG=configs/exp01_fedavg_resnet50_5nodes_server.yaml
#
# Para 6 nodos (RECOMENDADO):
SERVER_CONFIG=configs/exp01_fedavg_resnet50_6nodes_server.yaml
#
CLIENT_CONFIG=configs/exp01_fedavg_resnet50_client.yaml

# ── Red ────────────────────────────────────────────────────────────────
# Puerto publicado del servidor en el host.
SERVER_PORT=8080
#
# Dirección que usan los NODOS para llegar al servidor:
#   - UNA MÁQUINA (server + nodos en el mismo compose):  server:8080
#   - MÁQUINAS SEPARADAS (nodo en otro host):            <IP_LAN_servidor>:8080
#
# Ejemplo para máquinas separadas (reemplazar con tu IP LAN):
# SERVER_ADDRESS=192.168.14.184:8080
SERVER_ADDRESS=server:8080

# ── Datos por nodo ─────────────────────────────────────────────────────
# Carpeta de imágenes (relativa a la raíz del repo / montada en /app).
NODE_DATA_DIR=data/mammobench/images

# Manifests de partición por nodo (6 nodos + servidor)
# NOTA: Generar con: python scripts/partition_mammobench.py --csv data/mammobench/mammo-bench.csv --out manifests/ --nodes 6
#
# Nodo 0 (cmmd — China)
NODE0_MANIFEST=manifests/node0_manifest.csv
#
# Nodo 1 (dmid — Desconocido 1)
NODE1_MANIFEST=manifests/node1_manifest.csv
#
# Nodo 2 (ibia — Desconocido 2)
NODE2_MANIFEST=manifests/node2_manifest.csv
#
# Nodo 3 (cdd-cesm — Egipto)
NODE3_MANIFEST=manifests/node3_manifest.csv
#
# Nodo 4 (kau-bcmd — Arabia Saudita)
NODE4_MANIFEST=manifests/node4_manifest.csv
#
# Nodo 5 (ddsm — USA / CBIS-DDSM)
NODE5_MANIFEST=manifests/node5_manifest.csv
